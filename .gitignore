design-reference/**/_ds_bundle.js
design-reference/**/support.js

# pre-flip gates (council 2026-06-13)
# design-reference/: carries an unlicensed property-marketplace artifact and
# "Eigenstate" naming history; exclude the entire directory from the public surface.
design-reference/
# _claude/: development tooling (architecture notes, council docs, strategy);
